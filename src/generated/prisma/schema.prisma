  created_at    DateTime  @default(now()) @db.Timestamp(0)
  start_time    DateTime? @db.Timestamp(0)
  end_time      DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  @@index([modifier_type], map: "tec_order_modifier_index_modifier_type")
  @@index([slug], map: "tec_order_modifier_index_slug")
  @@index([status, modifier_type], map: "tec_order_modifier_index_status_modifier_type")
}

