  confirmation Int?    @default(0)
}

model wp_mec_booking_attendees {
  id              Int             @id @default(autoincrement()) @db.UnsignedInt
  mec_booking_id  Int             @db.UnsignedInt
  user_id         Int             @db.UnsignedInt
  ticket_id       Int             @db.UnsignedInt
  wp_mec_bookings wp_mec_bookings @relation(fields: [mec_booking_id], references: [id], onDelete: Cascade, map: "mec_booking_id")

  @@index([mec_booking_id], map: "mec_booking_id")
}

model wp_mec_bookings {
  id                       Int                        @id @default(autoincrement()) @db.UnsignedInt
  booking_id               Int                        @db.UnsignedInt
  user_id                  Int?                       @db.UnsignedInt
  transaction_id           String?                    @db.VarChar(20)
  event_id                 Int                        @db.UnsignedInt
  ticket_ids               String                     @db.VarChar(655)
  seats                    Int                        @default(0) @db.UnsignedInt
  status                   String                     @default("pending") @db.VarChar(20)
  confirmed                Int                        @default(0) @db.TinyInt
  verified                 Int                        @default(0) @db.TinyInt
  all_occurrences          Int                        @default(0) @db.TinyInt
  date                     DateTime                   @db.DateTime(0)
  timestamp                Int                        @db.UnsignedInt
  wp_mec_booking_attendees wp_mec_booking_attendees[]

  @@index([booking_id], map: "booking_id")
  @@index([event_id, ticket_ids, status, confirmed, verified, date], map: "event_id")
  @@index([timestamp], map: "timestamp")
  @@index([user_id], map: "user_id")
}

